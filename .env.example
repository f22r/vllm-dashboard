# Example .env for VLLM Dashboard
# Copy this to .env and set real values locally (DO NOT commit .env)

# Frontend Port
FRONTEND_PORT=5510

# Backend Port
BACKEND_PORT=5511

# vLLM Server URL
VLLM_URL=http://localhost:8001

# Hugging Face Token (Required for gated models like Llama 3)
# Create a token at https://huggingface.co/settings/tokens and paste here
HF_TOKEN=hf_your_token_here

# Allow long model contexts
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
# VLLM Dashboard Configuration

# Frontend Port
FRONTEND_PORT=5510

# Backend Port  
BACKEND_PORT=5511

# vLLM Server URL
VLLM_URL=http://localhost:8001

# Hugging Face Token (Required for gated models like Llama 3)
HF_TOKEN=your_token_here
